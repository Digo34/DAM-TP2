<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:background="@drawable/sunny_bg_land"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/weatherImage"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_launcher_foreground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.06"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TableLayout
        android:id="@+id/tableLayout"
        android:layout_width="488dp"
        android:layout_height="265dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="90dp"
        android:layout_marginEnd="10dp"
        android:stretchColumns="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Latitude -->
        <TableRow
            android:background="@color/viewBG">

            <TextView
                android:padding="5dp"
                android:text="@string/latitude" />

            <EditText
                android:id="@+id/latInput"
                android:layout_height="48dp"
                android:backgroundTint="#FFFFFF"
                android:inputType="numberDecimal|numberSigned"
                android:padding="5dp"
                android:text="@string/latitude_value" />
        </TableRow>

        <!-- Longitude -->
        <TableRow
            android:background="@color/viewBG">

            <TextView
                android:padding="5dp"
                android:text="@string/longitude" />

            <EditText
                android:id="@+id/lonInput"
                android:layout_width="113dp"
                android:layout_height="48dp"
                android:backgroundTint="#FFFFFF"
                android:inputType="numberDecimal|numberSigned"
                android:padding="5dp"
                android:text="@string/longitude_value" />
        </TableRow>

        <!-- Sea Level Pressure -->
        <TableRow
            android:background="@color/viewBG">

            <TextView
                android:padding="5dp"
                android:text="@string/sea_level_pressure" />

            <TextView
                android:id="@+id/pressureValue"
                android:padding="5dp" />
        </TableRow>

        <!-- Wind Direction -->
        <TableRow
            android:background="@color/viewBG">

            <TextView
                android:padding="5dp"
                android:text="@string/wind_direction" />

            <TextView
                android:id="@+id/windDirectionValue"
                android:padding="5dp" />
        </TableRow>

        <!-- Wind Speed -->
        <TableRow
            android:background="@color/viewBG">

            <TextView
                android:padding="5dp"
                android:text="@string/wind_speed" />

            <TextView
                android:id="@+id/windSpeedValue"
                android:padding="5dp" />
        </TableRow>

        <!-- Temperature -->
        <TableRow
            android:background="@color/viewBG">

            <TextView
                android:padding="5dp"
                android:text="@string/temperature" />

            <TextView
                android:id="@+id/temperatureValue"
                android:padding="5dp" />
        </TableRow>

        <!-- Time -->
        <TableRow
            android:background="@color/viewBG">

            <TextView
                android:padding="5dp"
                android:text="@string/time" />

            <TextView
                android:id="@+id/timeValue"
                android:padding="5dp" />
        </TableRow>

    </TableLayout>

    <Button
        android:id="@+id/updateButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/update"
        app:layout_constraintTop_toBottomOf="@id/tableLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>